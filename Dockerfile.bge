FROM python:3.11-slim
RUN pip install --no-cache-dir FlagEmbedding fastapi "uvicorn[standard]"
WORKDIR /app
COPY bge_server.py .
# The BAAI/bge-m3 model (~2.3 GB) downloads to /root/.cache/huggingface on first start.
# Mount a Railway Volume at /root/.cache/huggingface so it persists across redeploys.
EXPOSE 8080
CMD ["uvicorn", "bge_server:app", "--host", "0.0.0.0", "--port", "8080"]
