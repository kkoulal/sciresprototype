FROM neo4j:5-community
# No APOC needed at serve time — the agent only runs standard Cypher.
# Data is imported manually after first deploy (see hostingPlanSciresPrototype.md Step 10).
# Memory tuning: keep heap small so the Railway container fits in 2 GB.
ENV NEO4J_server_memory_heap_initial__size=512m
ENV NEO4J_server_memory_heap_max__size=1G
ENV NEO4J_server_memory_pagecache_size=512m
# Bolt only — no need to expose HTTP browser port publicly.
EXPOSE 7687
